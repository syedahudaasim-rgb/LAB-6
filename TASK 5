#include <stdio.h>

int main() {
    int units;
    int total = 0, count = 0;

    printf("Enter daily units (-999 to stop): ");
    scanf("%d", &units);

    while(units != -999) {
        total += units;
        count++;

        printf("Enter daily units (-999 to stop): ");
        scanf("%d", &units);
    }

    if(count > 0)
        printf("Average consumption: %.2f\n", (float)total / count);
    else
        printf("No data entered.\n");

    return 0;
}
